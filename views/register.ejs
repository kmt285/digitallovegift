<!DOCTYPE html>
<html>
<head><title>Register</title><link rel="stylesheet" href="/style.css"></head>
<body style="display: flex; justify-content: center; align-items: center; background: #111;">
    <div class="card" style="text-align: center; width: 300px;">
        <h2 class="glow-text" style="font-size: 2rem;">Register</h2>
        <% if (error) { %><p style="color: red;"><%= error %></p><% } %>
        <form action="/register" method="POST">
            <input type="text" name="username" placeholder="Username" required style="width: 90%; padding: 10px; margin: 10px 0; border-radius: 5px;"><br>
            <input type="password" name="password" placeholder="Password" required style="width: 90%; padding: 10px; margin: 10px 0; border-radius: 5px;"><br>
            <button type="submit" style="width: 100%;">Sign Up</button>
        </form>
        <p><a href="/login" style="color: #ff69b4;">Login ဝင်ရန်</a></p>
    </div>
</body>
</html>
