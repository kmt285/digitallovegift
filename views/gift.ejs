<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>For <%= gift.receiverName %> ❤️</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <canvas id="matrixCanvas"></canvas>
    
    <div id="countdown-container" class="center-content">
        <h1 id="countdown" class="glow-text" style="font-size: 5rem;">3</h1>
    </div>

    <div id="message-container" class="center-content hidden">
        <h1 class="glow-text">HAPPY BIRTHDAY<br>TO<br><%= gift.receiverName.toUpperCase() %></h1>
    </div>

    <div id="gallery-container" class="center-content hidden">
        <div class="gift-card glass-card">
            <img id="gallery-img" src="<%= gift.photos.length > 0 ? gift.photos[0] : 'https://via.placeholder.com/300x400/111/ff69b4?text=No+Photo' %>" alt="Love">
            <p id="gallery-text"><%= gift.messages.length > 0 ? gift.messages[0] : 'I love you' %></p>
            <button id="next-btn" class="btn btn-outline" style="margin-top: 20px;">Next ❤️</button>
        </div>
    </div>

    <script>
        const photosData = <%- JSON.stringify(gift.photos) %>;
        const messagesData = <%- JSON.stringify(gift.messages) %>;
    </script>
    <script src="/dynamic-script.js"></script>
</body>
</html>
