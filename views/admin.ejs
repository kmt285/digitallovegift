<!DOCTYPE html>
<html>
<head><title>Admin Panel</title><link rel="stylesheet" href="/style.css"></head>
<body style="padding: 20px; background: #111; color: white; text-align: center;">
    <h1 class="glow-text" style="font-size: 2.5rem;">Admin Control Panel</h1>
    <a href="/dashboard" style="color: #ff69b4; text-decoration: none; font-size: 1.2rem;">⬅ Back to Dashboard</a><br><br><br>

    <table border="1" style="width: 80%; margin: auto; border-collapse: collapse; text-align: center; border-color: #ff69b4;">
        <tr style="background: rgba(255,105,180,0.2);">
            <th style="padding: 15px; font-size: 1.2rem;">Username</th>
            <th style="font-size: 1.2rem;">Role</th>
            <th style="font-size: 1.2rem;">Status</th>
            <th style="font-size: 1.2rem;">Action</th>
        </tr>
        <% users.forEach(u => { %>
            <tr>
                <td style="padding: 15px; font-size: 1.1rem;"><%= u.username %></td>
                <td style="font-size: 1.1rem;"><%= u.role %></td>
                <td style="font-size: 1.1rem;">
                    <% if (u.isApproved) { %> <span style="color: #98fb98;">✅ Approved</span>
                    <% } else { %> <span style="color: #ffb6c1;">⏳ Pending</span> <% } %>
                </td>
                <td style="padding: 10px;">
                    <% if (u.username !== currentUser) { %>
                        <% if (u.isApproved) { %>
                            <form action="/admin/revoke/<%= u._id %>" method="POST" style="display:inline;">
                                <button style="border-color: red; color: red; padding: 5px 15px; font-size: 1rem;">Revoke</button>
                            </form>
                        <% } else { %>
                            <form action="/admin/approve/<%= u._id %>" method="POST" style="display:inline;">
                                <button style="border-color: #98fb98; color: #98fb98; padding: 5px 15px; font-size: 1rem;">Approve</button>
                            </form>
                        <% } %>
                    <% } else { %>
                        <span style="color: gray;">(You)</span>
                    <% } %>
                </td>
            </tr>
        <% }) %>
    </table>
</body>
</html>
